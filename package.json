{
  "name": "@yangjingo/skill-adapter",
  "version": "0.1.3-patch.1",
  "description": "Making Skills Evolve within your Workspace - A evolution management layer for Claude Code and OpenClaw",
  "main": "dist/index.js",
  "bin": {
    "sa": "dist/cli.js"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "postinstall": "bun scripts/ensure-gh.js || node scripts/ensure-gh.js",
    "build": "tsc",
    "start": "bun dist/cli.js || node dist/cli.js",
    "dev": "bun src/cli.ts || ts-node src/cli.ts",
    "slides": "bun scripts/slides.js || node scripts/slides.js",
    "setup:gh": "bun scripts/setup-gh.js || node scripts/setup-gh.js",
    "test": "bun tests/run-tests.js || node tests/run-tests.js",
    "test:all": "bun tests/run-tests.js --with-share-pr || node tests/run-tests.js --with-share-pr",
    "test:cli": "bun tests/test-scan-cli.js || node tests/test-scan-cli.js",
    "test:imports": "bun tests/test-imports.js || node tests/test-imports.js",
    "test:share-pr": "bun tests/test-share-pr.js || node tests/test-share-pr.js",
    "test:security": "bun tests/test-security.js || node tests/test-security.js",
    "test:versioning": "bun tests/test-versioning.js || node tests/test-versioning.js",
    "test:registry": "bun tests/test-registry.js || node tests/test-registry.js"
  },
  "keywords": [
    "claude-code",
    "openclaw",
    "skill",
    "evolution",
    "adapter",
    "security",
    "sharing",
    "discovery"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/ora": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "archiver": "^7.0.0",
    "commander": "^12.0.0",
    "ink": "^6.8.0",
    "js-yaml": "^4.1.0",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "skills": "^1.4.5"
  }
}
